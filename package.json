{
  "name": "agentmom",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "start": "NODE_ENV=production tsx src/server.ts",
    "smoke:auth": "tsx scripts/smoke-auth.ts && tsx scripts/smoke-workspace-catalog.ts && tsx scripts/smoke-telegram-catalog.ts",
    "smoke:local": "AGENTMOM_EXECUTOR=local tsx scripts/smoke-local.ts",
    "smoke:smolvm": "AGENTMOM_EXECUTOR=smolvm tsx scripts/smoke-smolvm.ts",
    "smoke:deploy": "AGENTMOM_EXECUTOR=local tsx scripts/smoke-deploy.ts"
  },
  "dependencies": {
    "@assistant-ui/react": "0.12.19",
    "@earendil-works/pi-ai": "0.79.1",
    "@earendil-works/pi-coding-agent": "0.79.1",
    "@vitejs/plugin-react": "^5.1.2",
    "grammy": "^1.43.0",
    "lucide-react": "^0.468.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  },
  "overrides": {
    "@assistant-ui/core": "0.1.7",
    "@assistant-ui/store": "0.2.3",
    "@assistant-ui/tap": "0.5.3"
  }
}
